    }
  },
  "templateParts": [
    {"name": "header", "area": "header"},
    {"name": "footer", "area": "footer"}
  ],
  "templates": [
    "front-page",
    "index",
    "single",
    "single-remorques",
    "archive",
    "search",
    "page-remorque"
  ]
